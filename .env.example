# Server
ADDR=:8081
DB_PATH=./data/platform.db

# Auth (single shared token for testers)
API_TOKEN=TEST123

# AI (DashScope 通义千问 — 必须用 compatible-mode)
AI_API_KEY=sk-your-key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
AI_MODEL=qwen-plus
# 上传设计稿截图时使用（需支持视觉的多模态模型）
AI_VISION_MODEL=qwen-vl-max

# qa-doc-generator（测试用例仓）
GITLAB_DOCS_PROJECT=Keccak256-evg/qa/qa-doc-generator
# 默认分支（页面会拉取全部分支供选择，此项仅作默认选中）
GITLAB_DOCS_REF=main

# 需求文档 · edgen-product-docs（GitHub）
GITHUB_PRD_REPO=Everest-Ventures-Group/edgen-product-docs
GITHUB_PRD_REF=main
# 可选：本地 clone 路径，配置后优先读本地而不调 GitHub API
# GITHUB_PRD_REPO_ROOT=/path/to/edgen-product-docs

# 后端技术方案 · osp-wiki（GitLab）
GITLAB_BE_PROJECT=Keccak256-evg/opensocial/osp-wiki
GITLAB_BE_REF=ospdev
GITLAB_BE_TREE=features

# GitLab Token：拉取 MR + test-docs + osp-wiki + **发表 MR 评论**（私有仓库必填）
# 创建 Token 时除 read_api、read_repository 外，需勾选 api（写评论）
# GITLAB_TOKEN=glpat-xxx

# 运行环境已全局统一管理（BETA / PRE / PROD），不再按项目划分

# GitHub Token（若使用 GitHub PR 模式）
# GITHUB_TOKEN=ghp_xxx